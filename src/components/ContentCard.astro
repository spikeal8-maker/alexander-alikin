---
import EvidenceBadge from './EvidenceBadge.astro';
import TopicList from './TopicList.astro';
import { formatDate } from '../lib/content';

interface Props {
  href: string;
  eyebrow: string;
  title: string;
  description: string;
  date: Date;
  topics?: string[];
  evidenceStatus?: 'verified' | 'self-reported' | 'requires-verification' | 'not-applicable';
}
const {
  href, eyebrow, title, description, date, topics = [],
  evidenceStatus = 'not-applicable'
} = Astro.props;
---
<article class="content-card">
  <p class="eyebrow">{eyebrow}</p>
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  <div class="card-meta">
    <span>{formatDate(date)}</span>
    <EvidenceBadge status={evidenceStatus} />
  </div>
  <TopicList topics={topics} />
</article>
