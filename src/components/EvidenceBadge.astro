---
interface Props {
  status: 'verified' | 'self-reported' | 'requires-verification' | 'not-applicable';
}
const { status } = Astro.props;
const labels = {
  verified: 'Подтверждено источником',
  'self-reported': 'Со слов автора',
  'requires-verification': 'Требует проверки',
  'not-applicable': 'Авторская позиция'
};
---
<span class:list={['evidence-badge', `evidence-${status}`]}>{labels[status]}</span>
