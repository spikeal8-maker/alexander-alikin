---
import { site } from '../data/site';
import { pagePath } from '../lib/url';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <p class="footer-title">Александр Аликин</p>
      <p>Инженер, педагог и предприниматель. Москва.</p>
    </div>
    <div>
      <p class="footer-label">Связаться</p>
      <a href={site.contact.primary} rel="me">Telegram</a>
      <a href={site.contact.max} rel="me">MAX</a>
    </div>
    <div>
      <p class="footer-label">Система</p>
      <a href={pagePath('/rss.xml')}>RSS</a>
      <a href={site.repository}>Исходный код</a>
      <a href={pagePath('/contacts/')}>Все контакты</a>
    </div>
  </div>
  <div class="shell footer-bottom">
    <span>© {year} Александр Аликин</span>
    <span>Факты отделяются от мнений и гипотез.</span>
  </div>
</footer>
