---
import EvidenceBadge from './EvidenceBadge.astro';
import TopicList from './TopicList.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  status: string;
  role: string;
  topics?: string[];
  evidenceStatus: 'verified' | 'self-reported' | 'requires-verification' | 'not-applicable';
}
const statusLabels: Record<string, string> = {
  active: 'Действующий',
  development: 'В разработке',
  completed: 'Завершён',
  archived: 'Архив',
  research: 'Исследование'
};
const { href, title, description, status, role, topics = [], evidenceStatus } = Astro.props;
---
<article class="project-card">
  <div class="project-card-top">
    <span class="status-pill">{statusLabels[status] ?? status}</span>
    <EvidenceBadge status={evidenceStatus} />
  </div>
  <h3><a href={href}>{title}</a></h3>
  <p>{description}</p>
  <p class="project-role"><strong>Роль:</strong> {role}</p>
  <TopicList topics={topics} />
</article>
