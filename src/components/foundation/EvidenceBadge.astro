---
interface Props {
  level: "author_statement" | "public_source" | "document_verified";
}

const { level } = Astro.props;
const labels = {
  author_statement: "Подтверждено автором",
  public_source: "Открытый источник",
  document_verified: "Проверено по документам",
};
---

<span
  class="evidence-badge"
  data-level={level}
  aria-label={`Уровень доказательности: ${labels[level]}`}
>
  {labels[level]}
</span>
