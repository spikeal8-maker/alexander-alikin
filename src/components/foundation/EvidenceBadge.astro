---
import type { EvidenceLevel } from "@config/site";

interface Props {
  level: EvidenceLevel;
}

const { level } = Astro.props;
const labels: Record<EvidenceLevel, string> = {
  author_statement: "Подтверждено автором",
  public_source: "Открытый источник",
  document_verified: "Проверено по документам",
};
---

<span class={`evidence-badge ${level}`} aria-label={`Уровень доказательности: ${labels[level]}`}>
  {labels[level]}
</span>
