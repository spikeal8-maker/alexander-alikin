---
import { navigation, buildUrl } from "@config/site";
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-section">
      <h3>Служебное</h3>
      <ul>
        {
          navigation.utility.map((item) => (
            <li>
              <a href={buildUrl(item.href)}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} Александр Аликин</p>
    </div>
  </div>
</footer>
