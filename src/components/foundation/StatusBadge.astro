---
interface Props {
  status: "draft" | "review" | "ready" | "published" | "blocked" | "archived";
}

const { status } = Astro.props;
const labels = {
  draft: "Черновик",
  review: "На проверке",
  ready: "Готово",
  published: "Опубликовано",
  blocked: "Заблокировано",
  archived: "Архив",
};
---

<span class={`badge badge-${status}`} aria-label={`Статус публикации: ${labels[status]}`}>
  {labels[status]}
</span>
