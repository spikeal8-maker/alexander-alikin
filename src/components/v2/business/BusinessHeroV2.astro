---
import { buildUrl } from "@config/site";
---

<section class="v2-section">
  <div class="v2-container v2-bh-grid">
    <div class="v2-bh-text">
      <h1 class="v2-page-title">Бизнесу</h1>
      <p class="v2-page-lead">
        ИИ, автоматизация, процессы. Превращаю разрозненные операции в измеримые системы с измеримым
        результатом.
      </p>
    </div>
    <div class="v2-bh-media">
      <img
        src={buildUrl("/images/alikin/visualized/business-ai-workflow.webp")}
        alt="AI-автоматизация бизнес-процессов"
        width="640"
        height="480"
        loading="eager"
        class="v2-img-frame"
      />
    </div>
  </div>
</section>

<style>
  .v2-bh-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .v2-bh-text {
    min-width: 0;
    overflow-wrap: break-word;
  }
  .v2-bh-media {
    min-width: 0;
  }
  .v2-bh-media img {
    max-height: 440px;
  }
  @media (max-width: 768px) {
    .v2-bh-grid {
      grid-template-columns: 1fr;
    }
    .v2-bh-media img {
      max-height: none;
    }
  }
</style>
