---
import { buildUrl } from "@config/site";
---

<section class="v2-section">
  <div class="v2-container">
    <h2 class="v2-section-title">Пример: ИЗО АСА</h2>
    <div class="v2-ce-grid">
      <div class="v2-ce-media">
        <img
          src={buildUrl("/images/alikin/visualized/robotics-lab.webp")}
          alt="ИЗО АСА — образовательная платформа"
          width="640"
          height="480"
          loading="eager"
          class="v2-img-frame"
        />
      </div>
      <div class="v2-ce-body">
        <h3>ИЗО АСА</h3>
        <p class="v2-ce-desc">
          Образовательная платформа для виртуальных лабораторий, управления классами и учебных
          проектов.
        </p>
        <dl class="v2-ce-meta">
          <div class="v2-ce-meta-item">
            <dt>Роль</dt>
            <dd>Автор архитектуры и разработчик</dd>
          </div>
          <div class="v2-ce-meta-item">
            <dt>Период</dt>
            <dd>2025–2026</dd>
          </div>
        </dl>
        <div class="v2-ce-done">
          <h4>Что сделано</h4>
          <p>
            Спроектирована и разработана архитектура ядра платформы, обеспечивающая модульность,
            масштабируемость и независимое развитие компонентов.
          </p>
        </div>
        <div class="v2-ce-scope">
          <h4>Модули</h4>
          <p>Виртуальные лаборатории, управление классами, проектная среда</p>
        </div>
        <a href={buildUrl("/projects/izo-asa/")} class="v2-btn v2-btn-outline">
          Смотреть кейс ИЗО АСА
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .v2-ce-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }
  .v2-ce-media {
    min-width: 0;
  }
  .v2-ce-media img {
    max-height: 360px;
    object-position: center 30%;
  }
  .v2-ce-body {
    min-width: 0;
    overflow-wrap: break-word;
  }
  .v2-ce-body h3 {
    font-size: var(--text-2xl);
    color: var(--color-white);
    margin: 0 0 var(--space-4);
    font-weight: var(--fw-bold);
    overflow-wrap: break-word;
  }
  .v2-ce-desc {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 var(--space-6);
    line-height: var(--leading-normal);
    overflow-wrap: break-word;
  }
  .v2-ce-meta {
    display: flex;
    gap: var(--space-8);
    margin-bottom: var(--space-6);
  }
  .v2-ce-meta-item {
    min-width: 0;
  }
  .v2-ce-meta dt {
    font-size: var(--text-xs);
    color: var(--color-accent-text);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .v2-ce-meta dd {
    font-size: var(--text-base);
    color: var(--color-white);
    margin: var(--space-1) 0 0;
    overflow-wrap: break-word;
  }
  .v2-ce-done {
    margin-bottom: var(--space-5);
  }
  .v2-ce-done h4 {
    font-size: var(--text-base);
    color: var(--color-accent-text);
    margin: 0 0 var(--space-2);
    font-weight: var(--fw-bold);
    overflow-wrap: break-word;
  }
  .v2-ce-done p {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: var(--leading-normal);
    overflow-wrap: break-word;
  }
  .v2-ce-scope {
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-lg);
  }
  .v2-ce-scope h4 {
    font-size: var(--text-sm);
    color: var(--color-accent-text);
    margin: 0 0 var(--space-2);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    overflow-wrap: break-word;
  }
  .v2-ce-scope p {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    line-height: var(--leading-normal);
    overflow-wrap: break-word;
  }
  @media (max-width: 768px) {
    .v2-ce-grid {
      grid-template-columns: 1fr;
    }
    .v2-ce-media img {
      max-height: 280px;
    }
  }
</style>
