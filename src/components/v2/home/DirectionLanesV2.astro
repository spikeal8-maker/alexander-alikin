---
import { buildUrl } from "@config/site";

const lanes = [
  {
    num: "01",
    title: "Бизнесу",
    desc: "ИИ, автоматизация, процессы. Превращаю разрозненные операции в измеримые системы.",
    href: "/business/",
  },
  {
    num: "02",
    title: "Образованию",
    desc: "Инженерные и ИИ-программы, лаборатории, методика проектного обучения.",
    href: "/education/",
  },
  {
    num: "03",
    title: "Обо мне",
    desc: "Путь и метод. От электроники до ИИ-систем — один метод для трёх профессий.",
    href: "/about/",
  },
];
---

<section class="v2-section v2-section-surface">
  <div class="v2-container">
    <h2 class="v2-section-title">Направления</h2>
    <div class="v2-lanes">
      {
        lanes.map((lane) => (
          <a href={buildUrl(lane.href)} class="v2-lane">
            <span class="v2-lane-num">{lane.num}</span>
            <div class="v2-lane-body">
              <h3>{lane.title}</h3>
              <p>{lane.desc}</p>
            </div>
            <span class="v2-lane-arrow" aria-hidden="true">
              &rarr;
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .v2-lanes {
    display: flex;
    flex-direction: column;
  }
  .v2-lane {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) 0;
    text-decoration: none;
    border-bottom: var(--border-width) solid var(--color-divider);
  }
  .v2-lane:first-child {
    border-top: var(--border-width) solid var(--color-divider);
  }
  .v2-lane-num {
    font-size: var(--text-5xl);
    font-weight: var(--fw-bold);
    color: var(--color-primary);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .v2-lane-body h3 {
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin: 0 0 var(--space-1);
  }
  .v2-lane-body p {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin: 0;
    max-width: 42rem;
  }
  .v2-lane-arrow {
    font-size: var(--text-2xl);
    color: var(--color-accent);
    opacity: 0.4;
    transition: opacity var(--motion-fast);
  }
  .v2-lane:hover .v2-lane-arrow {
    opacity: 1;
  }
  .v2-lane:hover .v2-lane-body h3 {
    color: var(--color-accent);
  }
  @media (max-width: 768px) {
    .v2-lane {
      grid-template-columns: auto 1fr;
      gap: var(--space-4);
      padding: var(--space-6) 0;
    }
    .v2-lane-body h3 {
      font-size: var(--text-xl);
      overflow-wrap: break-word;
    }
    .v2-lane-body p {
      overflow-wrap: break-word;
    }
    .v2-lane-arrow {
      display: none;
    }
    .v2-lane-num {
      font-size: var(--text-3xl);
    }
  }
</style>
