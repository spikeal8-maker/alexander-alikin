---
import { buildUrl } from "@config/site";
---

<section class="v2-hero">
  <div class="v2-hero-grid">
    <div class="v2-hero-text">
      <h1 class="v2-hero-name">Александр Аликин</h1>
      <p class="v2-hero-role">
        Предприниматель-практик и инженер-педагог. Проектирую и запускаю технологические, ИИ- и
        образовательные системы.
      </p>
      <div class="v2-hero-actions">
        <a href={buildUrl("/collaboration/")} class="v2-btn v2-btn-accent">Обсудить задачу</a>
        <a href={buildUrl("/projects/")} class="v2-btn v2-btn-outline">Проекты</a>
      </div>
    </div>
    <div class="v2-hero-media">
      <img
        src={buildUrl("/images/alikin/visualized/hero-main-business.webp")}
        alt="Александр Аликин — портрет"
        width="560"
        height="700"
        loading="eager"
        class="v2-hero-img"
      />
    </div>
  </div>
</section>

<style>
  .v2-hero {
    padding: var(--space-20) 0 var(--space-24);
  }
  .v2-hero-grid {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .v2-hero-name {
    font-size: var(--text-6xl);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 var(--space-6);
  }
  .v2-hero-role {
    font-size: var(--text-xl);
    color: rgba(255, 255, 255, 0.7);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-8);
    max-width: 34rem;
  }
  .v2-hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }
  .v2-hero-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    object-position: center 15%;
    max-height: 640px;
  }
  @media (max-width: 768px) {
    .v2-hero-grid {
      grid-template-columns: 1fr;
    }
    .v2-hero-name {
      font-size: var(--text-4xl);
    }
    .v2-hero {
      padding: var(--space-12) 0 var(--space-16);
    }
  }
</style>
