---
import { buildUrl } from "@config/site";
---

<section class="v2-hero">
  <div class="v2-container">
    <div class="v2-hero-grid">
      <div class="v2-hero-text">
        <h1 class="v2-hero-name">Александр Аликин</h1>
        <p class="v2-hero-role">
          Предприниматель-практик и инженер-педагог. Проектирую и запускаю технологические, ИИ- и
          образовательные системы.
        </p>
        <div class="v2-hero-actions">
          <a href={buildUrl("/collaboration/")} class="v2-btn v2-btn-accent">Обсудить задачу</a>
          <a href={buildUrl("/projects/")} class="v2-hero-link">Проекты &rarr;</a>
        </div>
      </div>
      <div class="v2-hero-media">
        <img
          src={buildUrl("/images/alikin/visualized/hero-main-business.webp")}
          alt="Александр Аликин — портрет"
          width="480"
          height="600"
          loading="eager"
          class="v2-hero-img"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .v2-hero {
    padding: var(--space-20) 0 var(--space-24);
    background: var(--color-bg);
  }
  .v2-hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }
  .v2-hero-name {
    font-size: var(--text-6xl);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 var(--space-6);
  }
  .v2-hero-role {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.7);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-8);
    max-width: 34rem;
  }
  .v2-hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .v2-hero-link {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: var(--text-base);
    font-weight: var(--fw-medium);
    transition: color var(--motion-fast);
  }
  .v2-hero-link:hover {
    color: var(--color-white);
  }
  .v2-hero-media {
    position: relative;
  }
  .v2-hero-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: cover;
    object-position: center 25%;
    max-height: 560px;
    filter: grayscale(0.2) contrast(1.05);
  }
  @media (max-width: 768px) {
    .v2-hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .v2-hero-name {
      font-size: var(--text-4xl);
    }
    .v2-hero {
      padding: var(--space-12) 0 var(--space-16);
    }
    .v2-hero-img {
      max-height: 400px;
    }
  }
</style>
