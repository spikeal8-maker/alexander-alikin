---
import { buildUrl } from "@config/site";
import { PROJECT_MEDIA, DEFAULT_MEDIA } from "./mediaMap";

export interface Props {
  project: {
    title: string;
    description: string;
    slug: string;
    role: string;
    period: string;
    result: string;
    projectStatus: "active" | "completed" | "paused" | "archived";
  };
}

const { project } = Astro.props;
const imgSrc = PROJECT_MEDIA[project.slug]?.hero ?? DEFAULT_MEDIA.hero;

const STATUS_LABEL: Record<string, string> = {
  active: "Активный",
  completed: "Завершён",
  paused: "Приостановлен",
  archived: "Архивный",
};
const statusLabel = STATUS_LABEL[project.projectStatus] ?? project.projectStatus;
---

<a href={buildUrl(`/projects/${project.slug}/`)} class="v2-editorial-card">
  <div class="v2-editorial-media">
    <img
      src={buildUrl(imgSrc)}
      alt=""
      width="600"
      height="450"
      loading="lazy"
      class="v2-editorial-img"
    />
  </div>
  <div class="v2-editorial-body">
    <h3>{project.title}</h3>
    <p class="v2-editorial-desc">{project.description}</p>
    <dl class="v2-editorial-meta-row">
      <div class="v2-editorial-meta-item">
        <dt>Роль</dt>
        <dd>{project.role}</dd>
      </div>
      <div class="v2-editorial-meta-item">
        <dt>Период</dt>
        <dd>{project.period}</dd>
      </div>
      <div class="v2-editorial-meta-item">
        <dt>Статус</dt>
        <dd>{statusLabel}</dd>
      </div>
    </dl>
    <span class="v2-editorial-link">Смотреть кейс &rarr;</span>
  </div>
</a>

<style>
  .v2-editorial-card {
    text-decoration: none;
    color: var(--color-white);
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-8);
    align-items: center;
    border: var(--border-width) solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--motion-fast);
  }
  .v2-editorial-card:hover {
    border-color: rgba(255, 255, 255, 0.2);
  }
  .v2-editorial-media {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .v2-editorial-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--motion-standard);
  }
  .v2-editorial-card:hover .v2-editorial-img {
    transform: scale(1.03);
  }
  .v2-editorial-body {
    padding: var(--space-6);
  }
  .v2-editorial-body h3 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-3);
  }
  .v2-editorial-body .v2-editorial-desc {
    color: rgba(255, 255, 255, 0.7);
    margin: 0 0 var(--space-5);
    line-height: var(--leading-normal);
    font-size: var(--text-base);
  }
  .v2-editorial-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin: 0 0 var(--space-4);
    padding: 0;
  }
  .v2-editorial-meta-item {
    font-size: var(--text-xs);
  }
  .v2-editorial-meta-item dt {
    color: var(--color-accent-text);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
  }
  .v2-editorial-meta-item dd {
    color: var(--color-white);
    margin: var(--space-1) 0 0;
  }
  .v2-editorial-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-accent-text);
    font-weight: var(--fw-semibold);
  }
  .v2-editorial-card:hover .v2-editorial-link {
    color: var(--color-white);
  }
  @media (max-width: 768px) {
    .v2-editorial-card {
      grid-template-columns: 1fr;
    }
  }
</style>
