---
import { buildUrl } from "@config/site";
import { PROJECT_MEDIA, DEFAULT_MEDIA } from "./mediaMap";

export interface Props {
  project: {
    title: string;
    description: string;
    slug: string;
    role: string;
    period: string;
    result: string;
    limitations?: string;
    projectStatus: "active" | "completed" | "paused" | "archived";
  };
  index: number;
}

const { project, index } = Astro.props;
const imgSrc = PROJECT_MEDIA[project.slug]?.hero ?? DEFAULT_MEDIA.hero;
const isReversed = index % 2 !== 0;

const STATUS_LABEL: Record<string, string> = {
  active: "В работе",
  completed: "Завершён",
  paused: "Приостановлен",
  archived: "Архивный проект",
};
const statusLabel = STATUS_LABEL[project.projectStatus] ?? project.projectStatus;
---

<a
  href={buildUrl(`/projects/${project.slug}/`)}
  class="v2-editorial-card"
  class:list={[{ "v2-editorial-card--reversed": isReversed }]}
>
  <div class="v2-editorial-media">
    <img
      src={buildUrl(imgSrc)}
      alt={`Иллюстрация проекта «${project.title}»`}
      width="600"
      height="450"
      loading="lazy"
      class="v2-editorial-img"
    />
  </div>
  <div class="v2-editorial-body">
    <span class="v2-accent-label">{statusLabel}</span>
    <h2>{project.title}</h2>
    <p class="v2-editorial-desc">{project.description}</p>
    <dl class="v2-editorial-meta-row">
      <div class="v2-editorial-meta-item">
        <dt>Роль</dt>
        <dd>{project.role}</dd>
      </div>
      <div class="v2-editorial-meta-item">
        <dt>Этап</dt>
        <dd>{project.period}</dd>
      </div>
    </dl>
    <div class="v2-editorial-result">
      <span class="v2-editorial-result-label">Что можно утверждать сейчас</span>
      <p class="v2-editorial-result-text">{project.result}</p>
    </div>
    {project.limitations && <p class="v2-editorial-limit">Ограничение: {project.limitations}</p>}
    <span class="v2-editorial-link">Открыть разбор &rarr;</span>
  </div>
</a>

<style>
  .v2-editorial-card {
    text-decoration: none;
    color: var(--color-white);
    display: grid;
    grid-template-columns: 3fr 2fr;
    align-items: stretch;
    border: var(--border-width) solid var(--color-border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .v2-editorial-card--reversed {
    grid-template-columns: 2fr 3fr;
  }
  .v2-editorial-card--reversed .v2-editorial-media {
    order: 2;
  }
  .v2-editorial-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    min-width: 0;
  }
  .v2-editorial-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--motion-standard);
  }
  .v2-editorial-card:hover .v2-editorial-img {
    transform: scale(1.03);
  }
  .v2-editorial-body {
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
  }
  .v2-editorial-body h2 {
    font-size: var(--text-2xl);
    margin: 0;
  }
  .v2-editorial-desc,
  .v2-editorial-result-text,
  .v2-editorial-limit {
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    line-height: var(--leading-normal);
    font-size: var(--text-base);
  }
  .v2-editorial-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin: 0;
  }
  .v2-editorial-meta-item dt,
  .v2-editorial-result-label {
    color: var(--color-accent-text);
    font-weight: var(--fw-bold);
    text-transform: uppercase;
    font-size: var(--text-xs);
  }
  .v2-editorial-meta-item dd {
    color: var(--color-white);
    margin: var(--space-1) 0 0;
    font-size: var(--text-base);
  }
  .v2-editorial-result {
    margin-top: var(--space-2);
  }
  .v2-editorial-result-label {
    display: block;
    margin-bottom: var(--space-1);
  }
  .v2-editorial-limit {
    color: rgba(255, 255, 255, 0.52);
    font-size: var(--text-sm);
  }
  .v2-editorial-link {
    color: var(--color-accent-text);
    font-weight: var(--fw-semibold);
    margin-top: auto;
    padding-top: var(--space-4);
  }
  @media (max-width: 768px) {
    .v2-editorial-card,
    .v2-editorial-card--reversed {
      grid-template-columns: 1fr;
    }
    .v2-editorial-card--reversed .v2-editorial-media {
      order: 0;
    }
  }
</style>
