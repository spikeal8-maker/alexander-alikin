---
import { buildUrl } from "@config/site";

const nav = [
  ["Обо мне", "/about/"],
  ["Проекты", "/projects/"],
  ["Бизнесу", "/business/"],
  ["Образованию", "/education/"],
  ["Журнал", "/journal/"],
];
---

<header class="v3-header">
  <div class="v3-header__inner">
    <a class="v3-header__brand" href={buildUrl("/")} aria-label="Александр Аликин — главная">
      <span class="v3-header__mark">АА</span>
      <span>Александр Аликин</span>
    </a>

    <nav class="v3-header__nav" aria-label="Основная навигация">
      {nav.map(([label, href]) => <a href={buildUrl(href)}>{label}</a>)}
    </nav>

    <a class="v3-header__cta" href={buildUrl("/collaboration/")}>Обсудить задачу</a>

    <details class="v3-header__mobile">
      <summary>Меню</summary>
      <nav aria-label="Мобильная навигация">
        {nav.map(([label, href]) => <a href={buildUrl(href)}>{label}</a>)}
        <a href={buildUrl("/collaboration/")}>Обсудить задачу</a>
      </nav>
    </details>
  </div>
</header>

<style>
  .v3-header {
    position: relative;
    z-index: 10;
    background: var(--v3-paper);
    border-bottom: 1px solid var(--v3-line);
  }

  .v3-header__inner {
    display: grid;
    grid-template-columns: minmax(15rem, 1fr) auto minmax(12rem, 1fr);
    gap: 2rem;
    align-items: center;
    width: min(100%, var(--v3-max));
    min-height: 5.25rem;
    margin: 0 auto;
    padding-inline: var(--v3-gutter);
  }

  .v3-header__brand {
    display: inline-flex;
    gap: 0.85rem;
    align-items: center;
    width: fit-content;
    font-size: 0.88rem;
    font-weight: 750;
    text-decoration: none;
  }

  .v3-header__mark {
    display: grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    color: var(--v3-white);
    background: var(--v3-ink);
    font-family: var(--v3-serif);
    font-size: 0.9rem;
    letter-spacing: -0.08em;
  }

  .v3-header__nav {
    display: flex;
    gap: clamp(1rem, 2vw, 2rem);
  }

  .v3-header__nav a,
  .v3-header__cta {
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
  }

  .v3-header__nav a {
    color: var(--v3-muted);
  }

  .v3-header__nav a:hover,
  .v3-header__nav a:focus-visible {
    color: var(--v3-ink);
  }

  .v3-header__cta {
    justify-self: end;
    padding-bottom: 0.25rem;
    color: var(--v3-cobalt);
    border-bottom: 2px solid currentColor;
  }

  .v3-header__mobile {
    display: none;
  }

  @media (max-width: 980px) {
    .v3-header__inner {
      grid-template-columns: 1fr auto;
    }

    .v3-header__nav,
    .v3-header__cta {
      display: none;
    }

    .v3-header__mobile {
      position: relative;
      display: block;
    }

    .v3-header__mobile summary {
      cursor: pointer;
      font-size: 0.78rem;
      font-weight: 750;
      list-style: none;
    }

    .v3-header__mobile summary::-webkit-details-marker {
      display: none;
    }

    .v3-header__mobile nav {
      position: absolute;
      top: 2rem;
      right: 0;
      display: grid;
      min-width: min(19rem, calc(100vw - 2.5rem));
      padding: 1.25rem;
      background: var(--v3-ink);
      box-shadow: var(--v3-shadow);
    }

    .v3-header__mobile nav a {
      padding: 0.8rem 0;
      color: var(--v3-white);
      border-bottom: 1px solid var(--v3-line-light);
      font-size: 0.95rem;
      text-decoration: none;
    }
  }
</style>