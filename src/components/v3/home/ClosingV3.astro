---
import { buildUrl } from "@config/site";
---

<section class="v3-closing v3-section">
  <div class="v3-shell v3-closing__grid">
    <p class="v3-kicker">Предметный разговор</p>
    <h2>Есть сложный процесс, программа или проект?</h2>
    <div class="v3-closing__copy">
      <p>
        Начнём с контекста: что происходит сейчас, где ограничение, какой результат действительно
        нужен и что нельзя обещать заранее.
      </p>
      <a href={buildUrl("/collaboration/")}>Обсудить задачу <span>↗</span></a>
    </div>
  </div>
</section>

<style>
  .v3-closing {
    background: var(--v3-cobalt);
    color: var(--v3-white);
  }

  .v3-closing__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(20rem, 0.65fr);
    column-gap: clamp(2rem, 8vw, 9rem);
    align-items: end;
  }

  .v3-closing .v3-kicker {
    grid-column: 1 / -1;
    color: rgba(255, 255, 255, 0.7);
  }

  .v3-closing h2 {
    max-width: 13ch;
    margin: 0;
    font-family: var(--v3-serif);
    font-size: clamp(3.5rem, 7vw, 8rem);
    font-weight: 400;
    letter-spacing: -0.06em;
    line-height: 0.9;
  }

  .v3-closing__copy p {
    margin: 0 0 2rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.7;
  }

  .v3-closing__copy a {
    display: flex;
    justify-content: space-between;
    padding: 1.2rem 0;
    color: var(--v3-white);
    border-top: 1px solid rgba(255, 255, 255, 0.45);
    border-bottom: 1px solid rgba(255, 255, 255, 0.45);
    font-size: 0.9rem;
    font-weight: 750;
    text-decoration: none;
  }

  .v3-closing__copy a:hover,
  .v3-closing__copy a:focus-visible {
    color: var(--v3-ink);
  }

  @media (max-width: 760px) {
    .v3-closing__grid {
      grid-template-columns: 1fr;
    }

    .v3-closing__copy {
      margin-top: 3rem;
    }
  }
</style>
