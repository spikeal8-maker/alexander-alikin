---
import { buildUrl } from "@config/site";

const modes = [
  {
    number: "01",
    title: "Разобрать",
    text: "Диагностика процесса, ограничений и зон потерь. Без обещания автоматизировать всё сразу.",
  },
  {
    number: "02",
    title: "Проверить",
    text: "Узкий прототип или программа, которую можно испытать на реальной задаче и объяснить участникам.",
  },
  {
    number: "03",
    title: "Передать",
    text: "Архитектура, документация и обучение — чтобы система продолжала работать без героизма автора.",
  },
];
---

<section class="v3-practice v3-section">
  <div class="v3-shell">
    <div class="v3-practice__lead">
      <p class="v3-kicker">Метод</p>
      <h2 class="v3-title">Не продаю магию.<br />Строю проверяемый переход.</h2>
      <p>
        Работа начинается не с выбора технологии, а с понимания системы. Хорошее решение можно
        проверить, объяснить и передать.
      </p>
    </div>

    <div class="v3-practice__steps">
      {modes.map((mode) => (
        <article>
          <span>{mode.number}</span>
          <h3>{mode.title}</h3>
          <p>{mode.text}</p>
        </article>
      ))}
    </div>

    <div class="v3-practice__routes">
      <a href={buildUrl("/business/")}>
        <span>Для бизнеса</span>
        <strong>Процессы, данные и ограниченные пилоты</strong>
      </a>
      <a href={buildUrl("/education/")}>
        <span>Для образования</span>
        <strong>Программы, лаборатории и методика</strong>
      </a>
      <a href={buildUrl("/about/")}>
        <span>Обо мне</span>
        <strong>Как сложился этот способ работы</strong>
      </a>
    </div>
  </div>
</section>

<style>
  .v3-practice {
    background: var(--v3-paper);
  }

  .v3-practice__lead {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.6fr);
    column-gap: clamp(2rem, 8vw, 9rem);
    align-items: end;
  }

  .v3-practice__lead .v3-kicker {
    grid-column: 1 / -1;
  }

  .v3-practice__lead > p:last-child {
    margin: 0;
    color: var(--v3-muted);
    line-height: 1.7;
  }

  .v3-practice__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin-top: clamp(4rem, 8vw, 8rem);
    border-top: 1px solid var(--v3-line);
    border-bottom: 1px solid var(--v3-line);
  }

  .v3-practice__steps article {
    min-height: 23rem;
    padding: 2rem clamp(1.25rem, 3vw, 3rem) 2.5rem 0;
    border-right: 1px solid var(--v3-line);
  }

  .v3-practice__steps article + article {
    padding-left: clamp(1.25rem, 3vw, 3rem);
  }

  .v3-practice__steps article:last-child {
    border-right: 0;
  }

  .v3-practice__steps span {
    color: var(--v3-cobalt);
    font-family: var(--v3-serif);
    font-size: 4.5rem;
    letter-spacing: -0.07em;
  }

  .v3-practice__steps h3 {
    margin: 4rem 0 1rem;
    font-family: var(--v3-serif);
    font-size: 2.3rem;
    font-weight: 400;
    letter-spacing: -0.04em;
  }

  .v3-practice__steps p {
    margin: 0;
    color: var(--v3-muted);
    font-size: 0.96rem;
    line-height: 1.65;
  }

  .v3-practice__routes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    margin-top: 1px;
    background: var(--v3-line);
  }

  .v3-practice__routes a {
    display: grid;
    gap: 1.5rem;
    min-height: 12rem;
    padding: 1.75rem;
    color: var(--v3-ink);
    background: var(--v3-white);
    text-decoration: none;
  }

  .v3-practice__routes span {
    color: var(--v3-cobalt);
    font-family: var(--v3-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .v3-practice__routes strong {
    align-self: end;
    max-width: 18rem;
    font-family: var(--v3-serif);
    font-size: 1.55rem;
    font-weight: 400;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }

  .v3-practice__routes a:hover,
  .v3-practice__routes a:focus-visible {
    color: var(--v3-white);
    background: var(--v3-cobalt);
  }

  .v3-practice__routes a:hover span,
  .v3-practice__routes a:focus-visible span {
    color: var(--v3-white);
  }

  @media (max-width: 760px) {
    .v3-practice__lead,
    .v3-practice__steps,
    .v3-practice__routes {
      grid-template-columns: 1fr;
    }

    .v3-practice__lead > p:last-child {
      margin-top: 2rem;
    }

    .v3-practice__steps article,
    .v3-practice__steps article + article {
      min-height: auto;
      padding: 2rem 0;
      border-right: 0;
      border-bottom: 1px solid var(--v3-line);
    }

    .v3-practice__steps article:last-child {
      border-bottom: 0;
    }

    .v3-practice__steps h3 {
      margin-top: 2rem;
    }
  }
</style>