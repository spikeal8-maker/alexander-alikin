---
import { buildUrl } from "@config/site";
---

<section class="v3-work v3-section">
  <div class="v3-shell">
    <header class="v3-work__header">
      <div>
        <p class="v3-kicker">Текущая практика</p>
        <h2 class="v3-title">Проекты, в которых метод становится системой</h2>
      </div>
      <p>
        Не витрина достижений, а рабочие контуры: что строится, какую роль я выполняю и где проходят
        границы утверждений.
      </p>
    </header>

    <article class="v3-work__feature v3-work__feature--blue">
      <div class="v3-work__visual" aria-hidden="true">
        <span class="v3-work__number">01</span>
        <div class="v3-work__orbit v3-work__orbit--one"></div>
        <div class="v3-work__orbit v3-work__orbit--two"></div>
        <div class="v3-work__node v3-work__node--a"></div>
        <div class="v3-work__node v3-work__node--b"></div>
        <div class="v3-work__node v3-work__node--c"></div>
      </div>
      <div class="v3-work__copy">
        <p class="v3-kicker">Активная разработка</p>
        <h3>ИЗО АСА</h3>
        <p>
          Образовательная платформа для виртуальных лабораторий, управления группами и учебных
          проектов. Сейчас сформированы архитектура ядра и модульная логика; публичная версия ещё не
          заявлена.
        </p>
        <dl>
          <div><dt>Роль</dt><dd>Архитектура и разработка</dd></div>
          <div><dt>Статус</dt><dd>Активная разработка</dd></div>
        </dl>
        <a class="v3-link" href={buildUrl("/projects/izo-asa/")}>Открыть кейс</a>
      </div>
    </article>

    <article class="v3-work__feature v3-work__feature--ink">
      <div class="v3-work__copy">
        <p class="v3-kicker">Практика и методика</p>
        <h3>Инженерное образование</h3>
        <p>
          Программы и проектные форматы по информатике, технологии и робототехнике. Участник не
          повторяет инструкцию: он создаёт, ошибается, объясняет решение и защищает результат.
        </p>
        <dl>
          <div><dt>Роль</dt><dd>Педагог и методист</dd></div>
          <div><dt>Фокус</dt><dd>Проектный инженерный цикл</dd></div>
        </dl>
        <a class="v3-link" href={buildUrl("/projects/engineering-education/")}>Открыть кейс</a>
      </div>
      <div class="v3-work__stairs" aria-hidden="true">
        <span>Действие</span><span>Ошибка</span><span>Объяснение</span><span>Защита</span>
      </div>
    </article>
  </div>
</section>

<style>
  .v3-work {
    background: var(--v3-white);
  }

  .v3-work__header {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 0.5fr);
    gap: clamp(2rem, 7vw, 8rem);
    align-items: end;
    margin-bottom: clamp(4rem, 8vw, 7rem);
  }

  .v3-work__header p:last-child {
    margin: 0;
    color: var(--v3-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .v3-work__feature {
    display: grid;
    min-height: 38rem;
    margin-top: 2rem;
  }

  .v3-work__feature--blue {
    grid-template-columns: minmax(0, 1.2fr) minmax(22rem, 0.8fr);
    color: var(--v3-white);
    background: var(--v3-cobalt);
  }

  .v3-work__feature--ink {
    grid-template-columns: minmax(22rem, 0.8fr) minmax(0, 1.2fr);
    color: var(--v3-white);
    background: var(--v3-ink);
  }

  .v3-work__copy {
    align-self: end;
    padding: clamp(2.25rem, 5vw, 5rem);
  }

  .v3-work__copy h3 {
    max-width: 10ch;
    margin: 0 0 1.5rem;
    font-family: var(--v3-serif);
    font-size: clamp(3rem, 6vw, 6.2rem);
    font-weight: 400;
    letter-spacing: -0.055em;
    line-height: 0.92;
  }

  .v3-work__copy > p:not(.v3-kicker) {
    max-width: 38rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 1rem;
    line-height: 1.7;
  }

  .v3-work__copy dl {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 2rem 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--v3-line-light);
  }

  .v3-work__copy dt {
    color: rgba(255, 255, 255, 0.48);
    font-family: var(--v3-mono);
    font-size: 0.64rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .v3-work__copy dd {
    margin: 0.45rem 0 0;
    font-size: 0.82rem;
  }

  .v3-work__copy .v3-link::after {
    color: currentColor;
  }

  .v3-work__visual {
    position: relative;
    overflow: hidden;
    min-height: 38rem;
    background: linear-gradient(135deg, rgba(255,255,255,0.05), transparent 55%);
  }

  .v3-work__number {
    position: absolute;
    top: 1rem;
    left: 2rem;
    font-family: var(--v3-serif);
    font-size: clamp(8rem, 20vw, 20rem);
    letter-spacing: -0.1em;
    line-height: 1;
    opacity: 0.16;
  }

  .v3-work__orbit {
    position: absolute;
    border: 1px solid rgba(255,255,255,0.48);
    border-radius: 50%;
  }

  .v3-work__orbit--one { inset: 20% 14% 16% 22%; }
  .v3-work__orbit--two { inset: 32% 28% 28% 10%; transform: rotate(24deg); }

  .v3-work__node {
    position: absolute;
    width: 1rem;
    height: 1rem;
    background: var(--v3-white);
    border-radius: 50%;
  }

  .v3-work__node--a { top: 24%; right: 21%; }
  .v3-work__node--b { right: 34%; bottom: 24%; }
  .v3-work__node--c { bottom: 35%; left: 18%; }

  .v3-work__stairs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    align-items: end;
    min-height: 38rem;
    padding: clamp(2rem, 5vw, 5rem);
    counter-reset: step;
  }

  .v3-work__stairs span {
    display: flex;
    min-height: calc(8rem + var(--step, 0) * 3rem);
    padding: 1rem;
    align-items: flex-end;
    border-top: 1px solid rgba(255,255,255,0.7);
    border-left: 1px solid rgba(255,255,255,0.2);
    font-family: var(--v3-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .v3-work__stairs span:nth-child(2) { transform: translateY(-3rem); }
  .v3-work__stairs span:nth-child(3) { transform: translateY(-6rem); }
  .v3-work__stairs span:nth-child(4) { transform: translateY(-9rem); }

  @media (max-width: 820px) {
    .v3-work__header,
    .v3-work__feature--blue,
    .v3-work__feature--ink {
      grid-template-columns: 1fr;
    }

    .v3-work__feature--ink .v3-work__copy {
      order: 2;
    }

    .v3-work__visual,
    .v3-work__stairs {
      min-height: 25rem;
    }
  }
</style>