---
import BaseLayout from './BaseLayout.astro';
import EvidenceBadge from '../components/EvidenceBadge.astro';
import TopicList from '../components/TopicList.astro';
import { formatDate } from '../lib/content';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  topics?: string[];
  evidenceStatus?: 'verified' | 'self-reported' | 'requires-verification' | 'not-applicable';
  eyebrow?: string;
}

const {
  title, description, publishedAt, updatedAt, topics = [],
  evidenceStatus = 'not-applicable', eyebrow = 'Материал'
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="article-shell section">
    <header class="article-header">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <div class="article-meta">
        <span>Опубликовано {formatDate(publishedAt)}</span>
        {updatedAt && <span>Обновлено {formatDate(updatedAt)}</span>}
        <EvidenceBadge status={evidenceStatus} />
      </div>
      <TopicList topics={topics} />
    </header>
    <div class="prose"><slot /></div>
  </article>
</BaseLayout>
