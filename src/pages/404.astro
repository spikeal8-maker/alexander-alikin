---
import BaseLayout from '../layouts/BaseLayout.astro';
import { pagePath } from '../lib/url';
---
<BaseLayout title="Страница не найдена" noindex>
  <section class="page-hero"><div class="shell narrow">
    <p class="eyebrow">404</p><h1>Такой страницы пока нет.</h1>
    <p class="lead">Возможно, материал перемещён или ещё не опубликован.</p>
    <a class="button button-primary" href={pagePath('/')}>Вернуться на главную</a>
  </div></section>
</BaseLayout>
