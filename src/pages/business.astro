---
import BaseLayoutV2 from "@layouts/BaseLayoutV2.astro";
import { buildUrl } from "@config/site";
---

<BaseLayoutV2
  title="Бизнесу — Александр Аликин"
  description="ИИ, автоматизация, процессы. Превращаю разрозненные операции в измеримые системы с измеримым результатом."
  currentPath="/business/"
>
  <!-- PAGE HERO -->
  <section class="v2-section">
    <div class="v2-container">
      <h1 class="v2-page-title">Бизнесу</h1>
      <p class="v2-page-lead">
        ИИ, автоматизация, процессы. Превращаю разрозненные операции в измеримые системы с
        измеримым результатом.
      </p>
    </div>
  </section>

  <!-- PROBLEM SIGNALS -->
  <section class="v2-section v2-section-dark">
    <div class="v2-container">
      <h2 class="v2-section-title">Когда стоит обратиться</h2>
      <div class="v2-signal-grid">
        <div class="v2-signal-card">
          <span class="v2-signal-num">01</span>
          <h3>Процессы разрослись</h3>
          <p>Операции делаются вручную, передача между сотрудниками ломается, данные теряются.</p>
        </div>
        <div class="v2-signal-card">
          <span class="v2-signal-num">02</span>
          <h3>Решения не оцифрованы</h3>
          <p>Выбор делается на основании интуиции, а не данных. Нет единой картины происходящего.</p>
        </div>
        <div class="v2-signal-card">
          <span class="v2-signal-num">03</span>
          <h3>Масштабирование буксует</h3>
          <p>То, что работало на 10 клиентов, не работает на 100. Нужна архитектура, а не
          заплатки.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BUSINESS OUTCOMES -->
  <section class="v2-section">
    <div class="v2-container">
      <h2 class="v2-section-title">Что получает бизнес</h2>
      <div class="v2-outcome-grid">
        <div class="v2-outcome-item">
          <span class="v2-method-num">Скорость</span>
          <p style="margin-top:var(--space-3);">Сокращение ручного труда в операционных цепочках.
          Автоматизация рутины.</p>
        </div>
        <div class="v2-outcome-item">
          <span class="v2-method-num">Прозрачность</span>
          <p style="margin-top:var(--space-3);">Единая картина: дашборды, метрики, логи. Решения на
          данных, а не на догадках.</p>
        </div>
        <div class="v2-outcome-item">
          <span class="v2-method-num">Масштаб</span>
          <p style="margin-top:var(--space-3);">Системная архитектура, которая выдерживает рост без
          пересборки заново.</p>
        </div>
        <div class="v2-outcome-item">
          <span class="v2-method-num">Независимость</span>
          <p style="margin-top:var(--space-3);">Передача системы команде с документацией, обучением и
          поддержкой.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FIVE STAGE PROCESS -->
  <section class="v2-section v2-section-dark">
    <div class="v2-container">
      <h2 class="v2-section-title">Метод работы</h2>
      <div class="v2-process-stages">
        <div class="v2-stage">
          <span class="v2-stage-num">01</span>
          <div>
            <h3>Диагностика</h3>
            <p>Интервью, аудит процессов, карта данных. Выявление узких мест и потерь. Две–три
            сессии.</p>
          </div>
        </div>
        <div class="v2-stage">
          <span class="v2-stage-num">02</span>
          <div>
            <h3>Проектирование</h3>
            <p>Архитектура решения, выбор стека, план пилота. Техническое задание с измеримыми
            критериями.</p>
          </div>
        </div>
        <div class="v2-stage">
          <span class="v2-stage-num">03</span>
          <div>
            <h3>Пилот</h3>
            <p>Ограниченный запуск на реальных данных. Прототип, который даёт измеримый результат, а
            не презентацию.</p>
          </div>
        </div>
        <div class="v2-stage">
          <span class="v2-stage-num">04</span>
          <div>
            <h3>Внедрение</h3>
            <p>Интеграция в рабочие процессы, миграция данных, обучение команды. Система без
            героических усилий автора.</p>
          </div>
        </div>
        <div class="v2-stage">
          <span class="v2-stage-num">05</span>
          <div>
            <h3>Сопровождение</h3>
            <p>Мониторинг, доработка по обратной связи, документация. Гарантия работоспособности на
            горизонте 3–6 месяцев.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE FORMATS -->
  <section class="v2-section">
    <div class="v2-container">
      <h2 class="v2-section-title">Форматы сотрудничества</h2>
      <div class="v2-signal-grid">
        <div class="v2-signal-card">
          <h3>Аудит и стратегия</h3>
          <p>Диагностика текущего состояния, карта автоматизации, дорожная карта. 2–4 недели.</p>
        </div>
        <div class="v2-signal-card">
          <h3>Проектная разработка</h3>
          <p>Полный цикл: от проектирования до передачи. Фиксированный результат и срок.</p>
        </div>
        <div class="v2-signal-card">
          <h3>Техническое лидерство</h3>
          <p>Временное усиление команды. Архитектура, код-ревью, наставничество разработчиков.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="v2-section v2-section-dark">
    <div class="v2-container v2-cta-block">
      <h2>Обсудим вашу задачу?</h2>
      <p>Если узнали свой случай в сигналах выше — напишите. Первая консультация без обязательств.</p>
      <a href={buildUrl("/collaboration/")} class="v2-btn v2-btn-accent">Обсудить задачу</a>
    </div>
  </section>
</BaseLayoutV2>

<style>
  .v2-section {
    padding: var(--space-24) 0;
  }
  .v2-section-dark {
    background: rgba(255, 255, 255, 0.02);
  }
  .v2-container {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .v2-page-title {
    font-size: var(--text-5xl);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    letter-spacing: -0.03em;
    margin: 0 0 var(--space-6);
  }
  .v2-page-lead {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.7);
    line-height: var(--leading-normal);
    max-width: 42rem;
    margin: 0;
  }
  .v2-section-title {
    font-size: var(--text-4xl);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    letter-spacing: var(--tracking-tight);
    margin: 0 0 var(--space-12);
  }
  .v2-signal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }
  .v2-signal-card {
    border: var(--border-width) solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    color: var(--color-white);
  }
  .v2-signal-num {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: var(--fw-bold);
    letter-spacing: 0.1em;
  }
  .v2-signal-card h3 {
    font-size: var(--text-xl);
    margin: var(--space-3) 0 var(--space-3);
  }
  .v2-signal-card p {
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: var(--leading-normal);
  }
  .v2-outcome-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-8);
  }
  .v2-outcome-item {
    color: var(--color-white);
  }
  .v2-outcome-item p {
    color: rgba(255, 255, 255, 0.6);
    line-height: var(--leading-normal);
  }
  .v2-method-num {
    font-size: var(--text-xs);
    color: var(--color-accent);
    font-weight: var(--fw-bold);
    letter-spacing: 0.1em;
  }
  .v2-process-stages {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  .v2-stage {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    padding: var(--space-6);
    border: var(--border-width) solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
  }
  .v2-stage-num {
    font-size: var(--text-2xl);
    font-weight: var(--fw-bold);
    color: var(--color-accent);
    min-width: 3rem;
    line-height: 1;
  }
  .v2-stage h3 {
    font-size: var(--text-lg);
    color: var(--color-white);
    margin: 0 0 var(--space-2);
  }
  .v2-stage p {
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: var(--leading-normal);
  }
  .v2-btn {
    display: inline-flex;
    align-items: center;
    padding: var(--space-4) var(--space-8);
    font-size: var(--text-base);
    font-weight: var(--fw-semibold);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--motion-fast);
    min-height: var(--target-size);
  }
  .v2-btn-accent {
    background: var(--color-accent);
    color: var(--color-white);
  }
  .v2-btn-accent:hover {
    background: var(--color-accent-hover);
  }
  .v2-cta-block {
    text-align: center;
    max-width: 42rem;
  }
  .v2-cta-block h2 {
    font-size: var(--text-4xl);
    color: var(--color-white);
    margin: 0 0 var(--space-4);
  }
  .v2-cta-block p {
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 var(--space-8);
    font-size: var(--text-lg);
  }
  @media (max-width: 768px) {
    .v2-page-title {
      font-size: var(--text-3xl);
    }
    .v2-section {
      padding: var(--space-16) 0;
    }
    .v2-section-title {
      font-size: var(--text-2xl);
    }
    .v2-signal-grid,
    .v2-outcome-grid {
      grid-template-columns: 1fr;
    }
    .v2-stage {
      flex-direction: column;
    }
  }
</style>
