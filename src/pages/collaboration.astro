---
import BaseLayoutV2 from "@layouts/BaseLayoutV2.astro";
import { buildUrl } from "@config/site";

const formats = [
  {
    title: "Аудит и стратегия",
    description: "Диагностика текущего состояния, карта автоматизации, дорожная карта. 2–4 недели.",
  },
  {
    title: "Проектная разработка",
    description: "Полный цикл: от проектирования до передачи. Фиксированный результат и срок.",
  },
  {
    title: "Техническое лидерство",
    description:
      "Временное усиление команды. Архитектура, код-ревью, наставничество разработчиков.",
  },
];
---

<BaseLayoutV2
  title="Обсудить задачу — Александр Аликин"
  description="Выберите формат сотрудничества: аудит, проектная разработка или техническое лидерство."
  currentPath="/collaboration/"
>
  <section class="v2-section">
    <div class="v2-container">
      <h1 class="v2-page-title">Обсудить задачу</h1>
      <p class="v2-page-lead">
        Выберите формат, который лучше всего подходит вашей ситуации. Каждое сотрудничество
        начинается с разбора контекста и фиксации ожидаемого результата.
      </p>
    </div>
  </section>

  <section class="v2-section v2-section-surface">
    <div class="v2-container">
      <h2 class="v2-section-title">Форматы сотрудничества</h2>
      <div class="v2-formats-grid">
        {
          formats.map((f, i) => (
            <div class="v2-card-surface v2-format-card">
              <span class="v2-accent-label">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="v2-format-card-title">{f.title}</h3>
              <p class="v2-format-card-desc">{f.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="v2-section">
    <div class="v2-container v2-cta-block">
      <h2>Готовы начать?</h2>
      <p>Напишите — разберём вашу задачу, оценим объём и предложим первый шаг.</p>
      <a href={buildUrl("/contacts/")} class="v2-btn v2-btn-accent">Связаться</a>
    </div>
  </section>
</BaseLayoutV2>
