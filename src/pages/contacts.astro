---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
---
<BaseLayout title="Контакты" description="Контакты и официальные площадки Александра Аликина.">
  <section class="page-hero"><div class="shell narrow">
    <p class="eyebrow">Контакты</p><h1>Официальные площадки</h1>
    <p class="lead">У каждой площадки своя роль. Сайт остаётся каноническим источником биографии, проектов и публикаций.</p>
  </div></section>
  <section class="section"><div class="shell contact-list">
    {site.socials.map((item) => (
      <article><h2><a href={item.url} rel="me">{item.name}</a></h2><p>{item.purpose}</p></article>
    ))}
  </div></section>
  <section class="section section-muted"><div class="shell narrow prose">
    <h2>Проекты</h2>
    <ul>{site.projects.map((item) => <li><a href={item.url}>{item.name}</a></li>)}</ul>
    <p>Публичная ссылка YouTube пока не указана: ранее переданный адрес ведёт в административную Google Cloud Console, а не на канал.</p>
  </div></section>
</BaseLayout>
