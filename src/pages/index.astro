---
import BaseLayout from "@layouts/BaseLayout.astro";
import HomeHero from "@components/home/HomeHero.astro";
import IntentRouter from "@components/home/IntentRouter.astro";
import NowSection from "@components/home/NowSection.astro";
import FeaturedProjects from "@components/home/FeaturedProjects.astro";
import MethodSection from "@components/home/MethodSection.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import Timeline from "@components/ui/Timeline.astro";
import CTASection from "@components/ui/CTASection.astro";
import { buildUrl } from "@config/site";
---

<BaseLayout
  title="Александр Аликин — проекты, системы и мысли"
  description="Предприниматель-практик и инженер-педагог. Проектирую и запускаю технологические, ИИ- и образовательные системы."
  currentPath="/"
>
  <HomeHero />
  <div class="container"><IntentRouter /></div>
  <div class="container mt-12"><NowSection /></div>
  <div class="container mt-12"><FeaturedProjects /></div>
  <div class="container mt-12 container-main"><MethodSection /></div>
  <div class="container mt-12 container-main">
    <SectionHeader label="Путь" title="Ключевые этапы" />
    <Timeline
      items={[
        {
          date: "2010-е",
          title: "Инженерия и техника",
          description: "Первые проекты, электроника, понимание систем.",
        },
        {
          date: "2015+",
          title: "Педагогика и робототехника",
          description: "Обучение, соревнования, методика.",
        },
        {
          date: "2018+",
          title: "Предпринимательство",
          description: "Лига роботов, Laser Love, бизнес-проекты.",
        },
        {
          date: "2024+",
          title: "ИИ и автоматизация",
          description: "Системы знаний, n8n, ИИ-ассистенты.",
        },
      ]}
    />
  </div>
  <div class="container">
    <CTASection
      title="Готовы обсудить задачу?"
      description="Если у вас есть процесс, который требует системы, или программа, которая должна давать измеримый результат — напишите."
      href={buildUrl("/collaboration/")}
      buttonLabel="Обсудить задачу"
    />
  </div>
</BaseLayout>
