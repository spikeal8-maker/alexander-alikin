---
import { getEntry, getCollection, render } from "astro:content";
import JournalEntryShellV2 from "@components/v2/journal/JournalEntryShellV2.astro";

export async function getStaticPaths() {
  const entries = await getCollection("articles", (entry) => entry.data.status === "published");
  return entries.map((entry) => ({ params: { slug: entry.data.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry("articles", slug);
if (!entry || entry.data.status !== "published") return Astro.redirect("/404");
const { Content } = await render(entry);
---

<JournalEntryShellV2
  title={entry.data.title}
  description={entry.data.description}
  kind="Статья"
  date={entry.data.publishedAt.toLocaleDateString("ru")}
  backHref="/journal/articles/"
  backLabel="Все статьи"
>
  <Content />
</JournalEntryShellV2>
