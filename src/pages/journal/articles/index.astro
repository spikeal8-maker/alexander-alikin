---
import { getCollection } from "astro:content";
import JournalListingV2 from "@components/v2/journal/JournalListingV2.astro";

const articles = (await getCollection("articles", (entry) => entry.data.status === "published"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: `/journal/articles/${entry.data.slug}/`,
    kind: "Статья",
    date: entry.data.publishedAt.toLocaleDateString("ru"),
  }));
---

<JournalListingV2
  title="Статьи"
  eyebrow="Развёрнутые материалы"
  description="Системные тексты, где тезис проходит через аргумент, структуру, ограничения и практический вывод."
  entries={articles}
/>
