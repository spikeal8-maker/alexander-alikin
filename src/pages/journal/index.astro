---
import BaseLayout from "@layouts/BaseLayout.astro";
import { buildUrl } from "@config/site";
---

<BaseLayout
  title="Журнал — Александр Аликин"
  description="Мысли, истории, статьи и новости. Авторское медиа о сложных системах, образовании и инженерии."
  currentPath="/journal/"
  breadcrumbs={[{ label: "Журнал" }]}
>
  <div class="container container-main">
    <h1>Журнал</h1>
    <p class="text-lg muted-text">
      Авторское медиа: истории, мысли, статьи, разборы, новости и видео.
    </p>
    <p>
      Материалы публикуются по мере редакционной готовности. Подпишитесь на <a
        href={buildUrl("/rss.xml")}>RSS</a
      > или следите за обновлениями.
    </p>
    <nav aria-label="Рубрики журнала" class="mt-8">
      <div class="card-grid">
        <a href={buildUrl("/journal/stories/")} class="card" style="text-decoration:none;">
          <h3 class="card-title">Истории</h3>
          <p class="card-description">
            Человеческие рассказы о выборе, ошибках и изменениях подхода.
          </p>
        </a>
        <a href={buildUrl("/journal/thoughts/")} class="card" style="text-decoration:none;">
          <h3 class="card-title">Мысли</h3>
          <p class="card-description">Короткие авторские тезисы, ведущие к проектам и историям.</p>
        </a>
        <a href={buildUrl("/journal/articles/")} class="card" style="text-decoration:none;">
          <h3 class="card-title">Статьи</h3>
          <p class="card-description">
            Системные материалы с аргументацией, источниками и смысловыми связями.
          </p>
        </a>
        <a href={buildUrl("/journal/news/")} class="card" style="text-decoration:none;">
          <h3 class="card-title">Новости</h3>
          <p class="card-description">
            Фактические обновления: запуски, публикации, события и изменения проектов.
          </p>
        </a>
      </div>
    </nav>
  </div>
</BaseLayout>
