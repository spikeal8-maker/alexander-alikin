---
import { getCollection } from "astro:content";
import JournalListingV2 from "@components/v2/journal/JournalListingV2.astro";

const news = (await getCollection("news", (entry) => entry.data.status === "published"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: `/journal/news/${entry.data.slug}/`,
    kind: "Новость",
    date: entry.data.publishedAt.toLocaleDateString("ru"),
  }));
---

<JournalListingV2
  title="Новости"
  eyebrow="Фактические обновления"
  description="Запуски, публикации и изменения проектов — только когда произошло проверяемое событие."
  entries={news}
/>
