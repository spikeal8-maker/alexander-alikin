---
import { getCollection } from "astro:content";
import JournalListingV2 from "@components/v2/journal/JournalListingV2.astro";

const stories = (await getCollection("stories", (entry) => entry.data.status === "published"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: `/journal/stories/${entry.data.slug}/`,
    kind: "История",
    date: entry.data.publishedAt.toLocaleDateString("ru"),
  }));
---

<JournalListingV2
  title="Истории"
  eyebrow="Опыт и изменение подхода"
  description="События и наблюдения, которые изменили способ проектировать, обучать и принимать решения."
  entries={stories}
/>
