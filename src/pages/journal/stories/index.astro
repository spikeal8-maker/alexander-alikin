---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { buildUrl } from "@config/site";

const stories = await getCollection("stories", (s) => s.data.status === "published");
---

<BaseLayout
  title="Истории — Александр Аликин"
  description="Человеческие истории о выборе, ошибках, изменениях подхода и том, чему научили реальные проекты."
  currentPath="/journal/"
  breadcrumbs={[{ label: "Журнал", href: "/journal/" }, { label: "Истории" }]}
>
  <div class="container">
    <div class="route-shell">
      <h1>Истории</h1>
      <p class="description">
        Рассказы о событиях, выборе, ошибках и том, чему научили реальные проекты.
      </p>
      {
        stories.map((s) => (
          <article style="margin-bottom:var(--space-lg);padding:var(--space-md);border:1px solid var(--color-border);border-radius:var(--radius);">
            <a
              href={buildUrl(`/journal/stories/${s.data.slug}/`)}
              style="font-weight:600;font-size:1.125rem;"
            >
              {s.data.title}
            </a>
            <p style="color:var(--color-muted);margin-top:var(--space-xs);">{s.data.description}</p>
          </article>
        ))
      }
      {stories.length === 0 && <p>Истории появятся после утверждения материалов.</p>}
    </div>
  </div>
</BaseLayout>
