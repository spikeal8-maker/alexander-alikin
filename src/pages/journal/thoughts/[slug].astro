---
import { getCollection, render } from "astro:content";
import JournalEntryShellV2 from "@components/v2/journal/JournalEntryShellV2.astro";

export async function getStaticPaths() {
  const entries = await getCollection("thoughts", (entry) => entry.data.status === "published");
  return entries.map((entry) => ({ params: { slug: entry.data.slug } }));
}

const { slug } = Astro.params;
const entry = (await getCollection("thoughts", (item) => item.data.status === "published")).find(
  (item) => item.data.slug === slug,
);
if (!entry) return Astro.redirect("/404");
const { Content } = await render(entry);
---

<JournalEntryShellV2
  title={entry.data.title}
  description={entry.data.description}
  kind="Мысль"
  date={entry.data.publishedAt.toLocaleDateString("ru")}
  backHref="/journal/thoughts/"
  backLabel="Все мысли"
>
  <Content />
</JournalEntryShellV2>
