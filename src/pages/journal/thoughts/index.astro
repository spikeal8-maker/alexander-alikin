---
import { getCollection } from "astro:content";
import JournalListingV2 from "@components/v2/journal/JournalListingV2.astro";

const thoughts = (await getCollection("thoughts", (entry) => entry.data.status === "published"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .map((entry) => ({
    title: entry.data.title,
    description: entry.data.description,
    href: `/journal/thoughts/${entry.data.slug}/`,
    kind: "Мысль",
    date: entry.data.publishedAt.toLocaleDateString("ru"),
  }));
---

<JournalListingV2
  title="Мысли"
  eyebrow="Короткие авторские тезисы"
  description="Идеи о системах, проектной работе, обучении и ИИ, которые можно проверить через практику."
  entries={thoughts}
/>
