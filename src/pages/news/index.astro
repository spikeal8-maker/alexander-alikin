---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentCard from '../../components/ContentCard.astro';
import { byNewest, isPublished } from '../../lib/content';
import { pagePath } from '../../lib/url';

const entries = (await getCollection('news', isPublished)).sort(byNewest);
---
<BaseLayout title="Новости" description="Запуски, публикации, события и обновления проектов.">
  <section class="page-hero"><div class="shell narrow">
    <p class="eyebrow">Что происходит</p><h1>Новости</h1><p class="lead">Запуски, публикации, события и обновления проектов.</p>
  </div></section>
  <section class="section"><div class="shell card-grid card-grid-three">
    {entries.map((entry) => (
      <ContentCard
        href={pagePath(`/news/${entry.id}/`)}
        eyebrow="Новость"
        title={entry.data.title}
        description={entry.data.description}
        date={entry.data.publishedAt}
        topics={entry.data.topics}
        evidenceStatus={entry.data.evidenceStatus}
      />
    ))}
  </div></section>
</BaseLayout>
