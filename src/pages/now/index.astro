---
import BaseLayout from "@layouts/BaseLayout.astro";
import { buildUrl } from "@config/site";
---

<BaseLayout
  title="Сейчас — Александр Аликин"
  description="Текущая деятельность и фокус."
  currentPath="/now/"
  breadcrumbs={[{ label: "Сейчас" }]}
>
  <div class="container container-main">
    <h1>Сейчас</h1>
    <p class="text-sm muted-text">Обновлено: июль 2026</p>
    <div class="now-list">
      <div class="now-item">
        <h3>Разрабатываю ИЗО АСА</h3><p>
          Образовательная платформа для виртуальных лабораторий и управления классами.
        </p>
      </div>
      <div class="now-item">
        <h3>Исследую автоматизацию образовательных процессов</h3><p>
          Проектирую системы на базе ИИ и n8n.
        </p>
      </div>
      <div class="now-item">
        <h3>Веду проекты по информатике и робототехнике</h3><p>
          Проектная деятельность, соревнования, методика.
        </p>
      </div>
      <div class="now-item">
        <h3>Собираю публичную базу знаний</h3><p>
          Формирую персональную цифровую платформу как канонический источник.
        </p>
      </div>
    </div>
    <p class="mt-8"><a href={buildUrl("/projects/")}>Посмотреть проекты</a></p>
  </div>
</BaseLayout>

<style>
  .now-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-6);
  }
  .now-item {
    padding: var(--space-4);
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-divider);
    border-radius: var(--radius-md);
  }
  .now-item h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-1);
  }
  .now-item p {
    color: var(--color-text-secondary);
    margin: 0;
  }
</style>
