---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate, isPublished } from '../../lib/content';

const items = (await getCollection('now', isPublished))
  .filter((item) => item.data.expiresAt >= new Date())
  .sort((a, b) => a.data.priority - b.data.priority);
const rendered = await Promise.all(
  items.map(async (entry) => ({ entry, rendered: await render(entry) }))
);
---
<BaseLayout title="Сейчас" description="Актуальные направления работы Александра Аликина.">
  <section class="page-hero"><div class="shell narrow">
    <p class="eyebrow">Сейчас</p><h1>Над чем я работаю</h1>
    <p class="lead">Текущий срез задач. Записи имеют срок актуальности и регулярно пересматриваются.</p>
  </div></section>
  <section class="section"><div class="shell now-list">
    {rendered.map(({ entry, rendered: { Content } }) => (
      <article>
        <p class="eyebrow">Актуально до {formatDate(entry.data.expiresAt)}</p>
        <h2>{entry.data.title}</h2>
        <p class="lead-small">{entry.data.description}</p>
        <div class="prose"><Content /></div>
      </article>
    ))}
  </div></section>
</BaseLayout>
