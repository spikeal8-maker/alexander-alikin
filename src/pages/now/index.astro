---
import BaseLayoutV2 from "@layouts/BaseLayoutV2.astro";
import { buildUrl } from "@config/site";
import "../../styles/v2-utility.css";

const focusItems = [
  {
    title: "ИЗО АСА",
    text: "Активная разработка архитектуры образовательной платформы для виртуальных лабораторий, групп и учебных проектов.",
  },
  {
    title: "Редакционная платформа",
    text: "Сайт, журнал и реестр источников приводятся к единой системе, где факт отделён от авторской интерпретации.",
  },
  {
    title: "Инженерное образование",
    text: "Развиваются проектные форматы, в которых участник создаёт, проверяет и объясняет работающий результат.",
  },
];
---

<BaseLayoutV2
  title="Сейчас — Александр Аликин"
  description="Публично подтверждённые текущие направления работы."
  currentPath="/now/"
>
  <section class="v2-section">
    <div class="v2-container v2-utility-hero">
      <div class="v2-utility-lead">
        <p class="v2-accent-label">Сейчас</p>
        <h1 class="v2-page-title">Текущий рабочий фокус</h1>
        <p>
          Здесь фиксируются только направления, которые подтверждены опубликованными проектами и
          текущим состоянием репозитория. Страница не используется как поток случайных обновлений.
        </p>
      </div>
      <div class="v2-utility-note">
        <p>
          Обновлено: июль 2026. Точные внешние результаты добавляются только вместе с источником.
        </p>
      </div>
    </div>
  </section>

  <section class="v2-section v2-section-surface">
    <div class="v2-container v2-utility-grid">
      {
        focusItems.map((item, index) => (
          <article class="v2-utility-card">
            <span class="v2-accent-label">{String(index + 1).padStart(2, "0")}</span>
            <h2>{item.title}</h2>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="v2-section">
    <div class="v2-container v2-cta-block">
      <h2>Посмотреть работу в контексте</h2>
      <p>Статусы, роли и ограничения раскрыты на страницах проектов.</p>
      <a href={buildUrl("/projects/")} class="v2-btn v2-btn-accent">Открыть проекты</a>
    </div>
  </section>
</BaseLayoutV2>
