---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Конфиденциальность — Александр Аликин"
  description="Политика обработки данных: какие данные собираются, зачем, где обрабатываются и как удалить."
  currentPath="/privacy/"
  breadcrumbs={[{ label: "Конфиденциальность" }]}
>
  <div class="container">
    <div class="route-shell">
      <h1>Конфиденциальность</h1>
      <p class="description">Политика обработки данных.</p>
      <p>
        На данный момент сайт не собирает персональные данные посетителей. Статический HTML не
        использует cookies, формы обратной связи или внешние аналитические сервисы. GitHub Pages
        может вести стандартные серверные логи.
      </p>
      <p>При появлении форм или аналитики политика будет обновлена до их подключения.</p>
    </div>
  </div>
</BaseLayout>
