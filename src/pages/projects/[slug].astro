---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import EvidenceBadge from "@components/foundation/EvidenceBadge.astro";
import ButtonLink from "@components/ui/ButtonLink.astro";
import { buildUrl } from "@config/site";

export async function getStaticPaths() {
  const projects = await getCollection("projects", (p) => p.data.status === "published");
  return projects.map((p) => ({ params: { slug: p.data.slug } }));
}

const { slug } = Astro.params;
const project = (await getCollection("projects", (p) => p.data.status === "published")).find(
  (p) => p.data.slug === slug,
);
if (!project) return Astro.redirect("/404");
const { data } = project;
const statusLabels = {
  active: "Активный",
  completed: "Завершён",
  paused: "Приостановлен",
  archived: "Архив",
};
---

<BaseLayout
  title={`${data.title} — Александр Аликин`}
  description={data.description}
  currentPath="/projects/"
  breadcrumbs={[{ label: "Проекты", href: "/projects/" }, { label: data.title }]}
>
  <div class="container container-main">
    <div
      style="display:flex;gap:var(--space-3);align-items:center;margin-bottom:var(--space-6);flex-wrap:wrap;"
    >
      <span class="badge badge-published"
        >{statusLabels[data.projectStatus] || data.projectStatus}</span
      >
      <EvidenceBadge level={data.evidenceLevel} />
      <span class="text-sm muted-text">{data.period}</span>
    </div>
    <h1>{data.title}</h1>
    <p class="text-lg muted-text">{data.description}</p>

    <div style="display:flex;flex-wrap:wrap;gap:var(--space-8);margin:var(--space-8) 0;">
      <div><div class="text-sm muted-text">Роль</div><div><strong>{data.role}</strong></div></div>
      <div>
        <div class="text-sm muted-text">Период</div><div><strong>{data.period}</strong></div>
      </div>
      <div>
        <div class="text-sm muted-text">Статус</div><div>
          <strong>{statusLabels[data.projectStatus] || data.projectStatus}</strong>
        </div>
      </div>
    </div>

    <h2>Результат</h2>
    <p>{data.result}</p>
    {
      data.limitations && (
        <>
          <>
            <h2>Ограничения</h2>
            <p>
              <em>{data.limitations}</em>
            </p>
          </>
        </>
      )
    }

    <hr />
    <ButtonLink href={buildUrl("/collaboration/")} variant="primary"
      >Обсудить похожую задачу</ButtonLink
    >
  </div>
</BaseLayout>
