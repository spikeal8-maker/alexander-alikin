---
import BaseLayoutV2 from "@layouts/BaseLayoutV2.astro";
import { getCollection } from "astro:content";
import ProjectCaseHeroV2 from "@components/v2/projects/ProjectCaseHeroV2.astro";
import CaseContextV2 from "@components/v2/projects/CaseContextV2.astro";
import CaseProblemV2 from "@components/v2/projects/CaseProblemV2.astro";
import CaseArchitectureV2 from "@components/v2/projects/CaseArchitectureV2.astro";
import CaseModulesV2 from "@components/v2/projects/CaseModulesV2.astro";
import CaseRoleV2 from "@components/v2/projects/CaseRoleV2.astro";
import CaseResultV2 from "@components/v2/projects/CaseResultV2.astro";
import CaseLimitationsV2 from "@components/v2/projects/CaseLimitationsV2.astro";
import CaseMaterialsV2 from "@components/v2/projects/CaseMaterialsV2.astro";
import CaseCtaV2 from "@components/v2/projects/CaseCtaV2.astro";

export async function getStaticPaths() {
  const ps = await getCollection("projects", (p) => p.data.status === "published");
  return ps.map((p) => ({ params: { slug: p.data.slug } }));
}

const { slug } = Astro.params;
const project = (await getCollection("projects", (p) => p.data.status === "published")).find(
  (p) => p.data.slug === slug,
);
if (!project) return Astro.redirect("/404");
const { data } = project;
---

<BaseLayoutV2
  title={`${data.title} — Александр Аликин`}
  description={data.description}
  currentPath="/projects/"
>
  <ProjectCaseHeroV2 data={data} />
  <CaseContextV2 description={data.description} />
  <CaseProblemV2 />
  <CaseArchitectureV2 />
  <CaseModulesV2 />
  <CaseRoleV2 role={data.role} />
  <CaseResultV2 result={data.result} />
  {data.limitations && <CaseLimitationsV2 limitations={data.limitations} />}
  <CaseMaterialsV2 />
  <CaseCtaV2 />
</BaseLayoutV2>
