---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { isPublished } from '../../lib/content';
import { pagePath } from '../../lib/url';

const entries = (await getCollection('projects', isPublished))
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Проекты" description="Продукты, образовательные системы, исследования и предпринимательские кейсы Александра Аликина.">
  <section class="page-hero"><div class="shell narrow">
    <p class="eyebrow">Практика</p><h1>Проекты</h1>
    <p class="lead">Задачи, роли, текущее состояние, доказательства и полученные выводы.</p>
  </div></section>
  <section class="section"><div class="shell card-grid card-grid-two">
    {entries.map((entry) => (
      <ProjectCard
        href={pagePath(`/projects/${entry.id}/`)}
        title={entry.data.title}
        description={entry.data.description}
        status={entry.data.status}
        role={entry.data.role}
        topics={entry.data.topics}
        evidenceStatus={entry.data.evidenceStatus}
      />
    ))}
  </div></section>
</BaseLayout>
