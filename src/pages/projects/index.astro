---
import BaseLayoutV2 from "@layouts/BaseLayoutV2.astro";
import { getCollection } from "astro:content";
import { buildUrl } from "@config/site";

const projects = await getCollection("projects", (p) => p.data.status === "published");
---

<BaseLayoutV2
  title="Проекты — Александр Аликин"
  description="Продукты, образовательные программы и технические инициативы."
  currentPath="/projects/"
>
  <section class="v2-section">
    <div class="v2-container">
      <h1 class="v2-page-title">Проекты</h1>
      <p class="v2-page-lead">
        Продукты, образовательные программы и технические инициативы. Каждый проект — это контекст,
        роль, решение и наблюдаемый результат.
      </p>
      <div class="v2-project-grid">
        {
          projects.map((p) => (
            <a href={buildUrl(`/projects/${p.data.slug}/`)} class="v2-project-card">
              <div class="v2-project-media">
                <img
                  src={buildUrl("/images/alikin/visualized/robotics-lab.webp")}
                  alt=""
                  width="600"
                  height="400"
                  loading="lazy"
                  class="v2-project-img"
                />
              </div>
              <div class="v2-project-body">
                <h3>{p.data.title}</h3>
                <p>{p.data.description}</p>
                <span class="v2-project-meta">
                  {p.data.period} · {p.data.role}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayoutV2>

<style>
  .v2-section {
    padding: var(--space-24) 0;
  }
  .v2-container {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  .v2-page-title {
    font-size: var(--text-5xl);
    font-weight: var(--fw-bold);
    color: var(--color-white);
    letter-spacing: -0.03em;
    margin: 0 0 var(--space-6);
  }
  .v2-page-lead {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-lg);
    max-width: 42rem;
    line-height: var(--leading-normal);
    margin: 0;
  }
  .v2-project-grid {
    margin-top: var(--space-12);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }
  .v2-project-card {
    text-decoration: none;
    color: var(--color-white);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
    border: var(--border-width) solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: border-color var(--motion-fast);
  }
  .v2-project-card:hover {
    border-color: rgba(255, 255, 255, 0.25);
  }
  .v2-project-media {
    aspect-ratio: 3/2;
    overflow: hidden;
    border-radius: var(--radius-md);
  }
  .v2-project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--motion-standard);
  }
  .v2-project-card:hover .v2-project-img {
    transform: scale(1.02);
  }
  .v2-project-body h3 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-2);
  }
  .v2-project-body p {
    color: rgba(255, 255, 255, 0.6);
    margin: 0 0 var(--space-3);
    line-height: var(--leading-normal);
  }
  .v2-project-meta {
    font-size: var(--text-xs);
    color: var(--color-accent);
  }
  @media (max-width: 768px) {
    .v2-page-title {
      font-size: var(--text-3xl);
    }
    .v2-section {
      padding: var(--space-16) 0;
    }
    .v2-project-card {
      grid-template-columns: 1fr;
    }
  }
</style>
