---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Поиск" description="Поиск по проектам, историям, мыслям и новостям Александра Аликина.">
  <section class="page-hero"><div class="shell narrow">
    <p class="eyebrow">Поиск</p><h1>Найти материал</h1>
    <p class="lead">Поиск работает по заголовкам, описаниям и темам опубликованных материалов.</p>
    <label class="search-box">
      <span>Запрос</span>
      <input id="search-input" type="search" placeholder="Например: робототехника, ИИ, бизнес" autocomplete="off" />
    </label>
  </div></section>
  <section class="section"><div class="shell narrow">
    <p id="search-status">Начните вводить запрос.</p>
    <div id="search-results" class="search-results"></div>
  </div></section>
  <script>
    const input = document.querySelector('#search-input');
    const status = document.querySelector('#search-status');
    const results = document.querySelector('#search-results');
    let index = [];

    async function loadIndex() {
      if (index.length) return;
      const response = await fetch(`${import.meta.env.BASE_URL}search-index.json`);
      index = await response.json();
    }

    function escapeHtml(value) {
      return value.replace(/[&<>"']/g, (character) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;'
      })[character]);
    }

    input?.addEventListener('input', async (event) => {
      await loadIndex();
      const query = event.target.value.trim().toLocaleLowerCase('ru');
      results.innerHTML = '';
      if (query.length < 2) {
        status.textContent = 'Введите минимум два символа.';
        return;
      }
      const found = index.filter((item) =>
        [item.title, item.description, ...(item.topics ?? [])]
          .join(' ').toLocaleLowerCase('ru').includes(query)
      );
      status.textContent = found.length ? `Найдено: ${found.length}` : 'Совпадений нет.';
      results.innerHTML = found.map((item) => `
        <article>
          <p class="eyebrow">${escapeHtml(item.type)}</p>
          <h2><a href="${escapeHtml(item.url)}">${escapeHtml(item.title)}</a></h2>
          <p>${escapeHtml(item.description)}</p>
        </article>
      `).join('');
    });
  </script>
</BaseLayout>
